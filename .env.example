# Copy this file to .env and fill in the values before deploying.

# --- Database ---
DB_PASSWORD=change_me_strong_password

# --- JWT ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_min_32_chars

# --- App URLs ---
# The public URL your site will be served from (no trailing slash)
FRONTEND_URL=http://your-vps-ip-or-domain

# --- Optional: Ollama AI (leave blank to use fallback macros) ---
OLLAMA_URL=http://host-gateway:11434

# --- Optional: Email (leave blank to skip sending emails) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@fittrack.com

# --- Optional: allow an extra CORS origin (e.g. staging domain) ---
EXTRA_CORS_ORIGIN=
