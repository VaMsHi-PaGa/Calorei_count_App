# Backend Environment Configuration
# Copy this file to .env and set the values for your environment

# Database
DATABASE_URL=postgresql://fitness_user:your_password@localhost/fitness_app
# For development with SQLite: DATABASE_URL=sqlite:///./fitness.db

# JWT Configuration (REQUIRED - set to a random secret key)
JWT_SECRET_KEY=your-very-long-random-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# Ollama Configuration (optional - for AI-powered food analysis)
OLLAMA_URL=http://localhost:11434

# Email Configuration (optional - for password reset and welcome emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@fittrack.com

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
